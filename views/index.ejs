<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Yuvraj Manoj Pawar - Portfolio</title>
    <meta name="description" content="Portfolio of Yuvraj Manoj Pawar, a passionate Web Developer.">
    <link rel="stylesheet" href="css/style.css">
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Mulish:wght@300;400;500;600;700;800;900&family=Poppins:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <!-- Font Awesome for Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="dark-mode" data-color="brown">
    <!-- Preloader -->
    <div id="preloader">
        <div class="loader_line"></div>
    </div>

    <!-- Custom Cursor -->
    <div class="cursor-dot" data-cursor-dot></div>
    <div class="cursor-outline" data-cursor-outline></div>

    <!-- Header & Navigation -->
    <header class="header">
        <div class="container nav-container">
            <div class="logo">
                <a href="#home">Yuvraj Manoj Pawar</a>
            </div>
            
            <button class="hamburger" id="hamburger" aria-label="Toggle navigation">
                <span class="bar"></span>
                <span class="bar"></span>
                <span class="bar"></span>
            </button>

            <nav class="nav" id="nav">
                <ul class="nav-links">
                    <li><a href="#home" class="nav-link">Home</a></li>
                    <li><a href="#about" class="nav-link">About</a></li>
                    <li><a href="#experience" class="nav-link">Experience</a></li>
                    <li><a href="#skills" class="nav-link">Tech Stack</a></li>
                    <li><a href="#projects" class="nav-link">Projects</a></li>
                    <li><a href="#contact" class="nav-link">Contact</a></li>
                </ul>
                <div class="nav-actions">
                    <button class="theme-toggle" id="theme-toggle" aria-label="Toggle dark/light mode">
                        <i class="fas fa-moon"></i>
                    </button>
                    <a href="#contact" class="btn btn-primary btn-hire">Hire Me</a>
                </div>
            </nav>
        </div>
    </header>

    <main>
        <!-- Hero Section -->
        <section id="home" class="hero">
            <div class="container hero-container">
                <div class="hero-content fade-in-up">
                    <div class="job">
                        <h3 class="greeting">Web Developer</h3>
                    </div>
                    <h1 class="hero-title">Yuvraj<br>Manoj Pawar</h1>
                    <h2 class="hero-subtitle">A passionate Web Developer focused on building functional and scalable web applications.</h2>
                    <div class="hero-buttons">
                        <a href="/api/resume/download" class="btn btn-primary">Download Resume</a>
                        <a href="#projects" class="btn btn-secondary">View Projects</a>
                    </div>
                </div>
                <div class="hero-shape fade-in">
                    <!-- Abstract shape or image container -->
                    <div class="shape-blob">
                        <img src="images/profile.png" alt="Yuvraj Manoj Pawar" class="profile-img">
                    </div>
                </div>
            </div>
        </section>

        <!-- About Me Section -->
        <section id="about" class="about section">
            <div class="container">
                <h2 class="section-title">About Me</h2>
                <div class="about-content">
                    <div class="about-text fade-in-up">
                        <p class="bio">Motivated and detail-oriented web developer with a strong foundation in front-end and back-end technologies. Seeking to leverage my academic background in Computer Applications and hands-on project experience to build dynamic web solutions and contribute effectively to an innovative tech team.</p>
                        
                        <div class="about-details">
                            <div class="detail-box">
                                <h3><i class="fas fa-language"></i> Languages Known</h3>
                                <p>English, Hindi, Marathi</p>
                            </div>
                            <div class="detail-box">
                                <h3><i class="fas fa-heart"></i> Hobbies</h3>
                                <p>Coding and Gym/Fitness</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Experience & Education Section -->
        <section id="experience" class="experience section bg-alt">
            <div class="container">
                <h2 class="section-title">Experience & Education</h2>
                <div class="timeline-container">
                    
                    <!-- Experience Timeline -->
                    <div class="timeline-column fade-in-left">
                        <h3 class="column-title"><i class="fas fa-briefcase"></i> Experience</h3>
                        <div class="timeline">
                            <div class="timeline-item">
                                <div class="timeline-dot"></div>
                                <div class="timeline-content card">
                                    <h4 class="role">Web Developer (On-Job Training)</h4>
                                    <h5 class="company">TVD SOFTWARE SOLUTION</h5>
                                    <span class="duration"><i class="far fa-calendar-alt"></i> Feb 16, 2026 – Feb 27, 2026</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Education Timeline -->
                    <div class="timeline-column fade-in-right">
                        <h3 class="column-title"><i class="fas fa-graduation-cap"></i> Education</h3>
                        <div class="timeline">
                            <div class="timeline-item">
                                <div class="timeline-dot"></div>
                                <div class="timeline-content card">
                                    <h4 class="role">Bachelor of Business Administration in Computer Application (B.B.A.C.A)</h4>
                                    <h5 class="company">New Arts, Commerce and Science College</h5>
                                    <span class="duration"><i class="far fa-calendar-alt"></i> 2026 | SGPA: 7.55 / 10</span>
                                    <p style="margin-top: 0.5rem; color: var(--text-secondary); font-size: 0.9rem;">Pursuing graduation with a focus on programming, databases, and software development.</p>
                                </div>
                            </div>
                            <div class="timeline-item">
                                <div class="timeline-dot"></div>
                                <div class="timeline-content card">
                                    <h4 class="role">Higher Secondary Education (HSC)</h4>
                                    <h5 class="company">New Arts, Commerce and Science College</h5>
                                    <span class="duration"><i class="far fa-calendar-alt"></i> 2023 | Score: 70.30%</span>
                                    <p style="margin-top: 0.5rem; color: var(--text-secondary); font-size: 0.9rem;">Completed with a focus on Commerce, Economics and Accounts.</p>
                                </div>
                            </div>
                            <div class="timeline-item">
                                <div class="timeline-dot"></div>
                                <div class="timeline-content card">
                                    <h4 class="role">Secondary Education (SSC)</h4>
                                    <h5 class="company">Rupibai Motilalji Bora New English School</h5>
                                    <span class="duration"><i class="far fa-calendar-alt"></i> 2021 | Score: 65.40%</span>
                                    <p style="margin-top: 0.5rem; color: var(--text-secondary); font-size: 0.9rem;">Built a strong foundation in core academic subjects.</p>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </section>

        <!-- Skills & Tech Stack Section -->
        <section id="skills" class="skills section">
            <div class="container">
                <h2 class="section-title">Skills & Tech Stack</h2>
                <div class="skills-grid fade-in-up">
                    
                    <div class="skill-category card">
                        <h3>Frontend</h3>
                        <div class="badges">
                            <span class="badge"><i class="fab fa-html5"></i> HTML</span>
                            <span class="badge"><i class="fab fa-css3-alt"></i> CSS</span>
                            <span class="badge"><i class="fab fa-js"></i> JavaScript</span>
                            <span class="badge"><i class="fab fa-bootstrap"></i> Bootstrap</span>
                        </div>
                    </div>

                    <div class="skill-category card">
                        <h3>Backend & Programming</h3>
                        <div class="badges">
                            <span class="badge"><i class="fab fa-node-js"></i> Node.js</span>
                            <span class="badge"><i class="fas fa-server"></i> Express.js</span>
                            <span class="badge"><i class="fab fa-java"></i> Java</span>
                            <span class="badge"><i class="fas fa-code"></i> C</span>
                            <span class="badge"><i class="fas fa-code"></i> C++</span>
                            <span class="badge"><i class="fas fa-project-diagram"></i> DSA</span>
                        </div>
                    </div>

                    <div class="skill-category card">
                        <h3>Database</h3>
                        <div class="badges">
                            <span class="badge"><i class="fas fa-database"></i> MySQL</span>
                            <span class="badge"><i class="fas fa-database"></i> DBMS</span>
                            <span class="badge"><i class="fas fa-database"></i> RDBMS</span>
                            <span class="badge"><i class="fas fa-leaf"></i> MongoDB</span>
                        </div>
                    </div>

                    <div class="skill-category card">
                        <h3>Tools</h3>
                        <div class="badges">
                            <span class="badge"><i class="fab fa-windows"></i> MS Office</span>
                            <span class="badge"><i class="fas fa-file-word"></i> MS Word</span>
                        </div>
                    </div>

                </div>
            </div>
        </section>

        <!-- Projects Section -->
        <section id="projects" class="projects section bg-alt">
            <div class="container">
                <h2 class="section-title">Projects</h2>
                <div class="projects-grid">
                    <% projects.forEach((project, index) => { %>
                        <div class="project-card card fade-in-up" id="project-<%= project.id %>" data-delay="<%= 0.2 + (index * 0.2) %>s">
                            <div class="project-image">
                                <img src="/<%= project.image %>" alt="<%= project.title %>" class="img-placeholder" style="object-fit: cover; width: 100%; height: 200px;">
                            </div>
                            <div class="project-info">
                                <h3 class="project-title"><%= project.title %></h3>
                                <p class="project-desc"><%= project.description %></p>
                                <div class="project-links">
                                    <% if (project.github && project.github !== '#') { %>
                                        <a href="<%= project.github %>" class="btn btn-outline btn-sm" target="_blank" rel="noopener noreferrer"><i class="fab fa-github"></i> GitHub Source</a>
                                    <% } %>
                                    <% if (project.live && project.live !== '#') { %>
                                        <a href="<%= project.live %>" class="btn btn-primary btn-sm" target="_blank" rel="noopener noreferrer"><i class="fas fa-external-link-alt"></i> Live</a>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>
                <script>
                    document.querySelectorAll('.project-card[data-delay]').forEach(card => {
                        card.style.transitionDelay = card.getAttribute('data-delay');
                    });
                </script>
            </div>
        </section>

        <!-- Contact Section -->
        <section id="contact" class="contact section">
            <div class="container text-center">
                <h2 class="section-title">Get In Touch</h2>
                <p class="section-subtitle fade-in-up" style="text-align: center; color: var(--text-secondary); margin-bottom: 3rem;">I'm open to internship opportunities, fresher roles, freelance work, and interesting collaborations. You can send me a message directly from here:</p>
                
                <div class="contact-cards fade-in-up" style="margin-bottom: 3rem;">
                    <a href="tel:+918010378717" class="info-item card" style="text-decoration: none; cursor: pointer;">
                        <div class="icon-box">
                            <i class="fas fa-phone-alt"></i>
                        </div>
                        <h4>Phone</h4>
                        <p style="color: var(--text-secondary); font-size: 1rem; margin: 0;">+91 8010378717</p>
                    </a>
                    
                    <a href="mailto:yuvraj.m.pawar2006@gmail.com" class="info-item card" style="text-decoration: none; cursor: pointer;">
                        <div class="icon-box">
                            <i class="fas fa-envelope"></i>
                        </div>
                        <h4>Email</h4>
                        <p style="color: var(--text-secondary); font-size: 1rem; margin: 0;">yuvraj.m.pawar2006@gmail.com</p>
                    </a>
                    
                    <a href="https://www.google.com/maps/search/?api=1&query=Dattarange+Mala,+Mahadev+Mandir,+Nalegaon,+Ahmednagar,+Maharashtra+414001" target="_blank" rel="noopener noreferrer" class="info-item card" style="text-decoration: none; cursor: pointer;">
                        <div class="icon-box">
                            <i class="fas fa-map-marker-alt"></i>
                        </div>
                        <h4>Address</h4>
                        <p style="color: var(--text-secondary); font-size: 1rem; margin: 0;">Dattarange Mala, Mahadev Mandir, Nalegaon, Ahmednagar, Maharashtra - 414001.</p>
                    </a>
                </div>

            </div>
        </section>
    </main>

    <!-- Footer -->
    <footer class="footer">
        <div class="container footer-container">
            <div class="footer-social">
                <a href="https://www.linkedin.com/in/yuvraj-pawar-b0a4b1301" aria-label="LinkedIn" target="_blank" rel="noopener noreferrer"><i class="fab fa-linkedin-in"></i></a>
                <a href="https://github.com/123yuvra" aria-label="GitHub" target="_blank" rel="noopener noreferrer"><i class="fab fa-github"></i></a>
            </div>
            <div class="footer-copy">
                &copy; <span id="year"></span> Yuvraj Manoj Pawar. All rights reserved.
            </div>
            <button id="backToTop" class="back-to-top" aria-label="Back to top">
                <i class="fas fa-chevron-up"></i>
            </button>
        </div>
    </footer>

    <!-- Toast Notification Container -->
    <div id="toast-container" class="toast-container"></div>

    <script src="/socket.io/socket.io.js"></script>
    <script>
        const socket = io();
        
        function showToast(message) {
            const container = document.getElementById('toast-container');
            const toast = document.createElement('div');
            toast.className = 'toast show';
            toast.innerHTML = `<i class="fas fa-bell"></i> ${message}`;
            container.appendChild(toast);
            
            setTimeout(() => {
                toast.classList.remove('show');
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        function buildCardHtml(project, isNew = false) {
            let linksHtml = '';
            if (project.github && project.github !== '#') {
                linksHtml += `<a href="${project.github}" class="btn btn-outline btn-sm" target="_blank" rel="noopener noreferrer"><i class="fab fa-github"></i> GitHub Source</a> `;
            }
            if (project.live && project.live !== '#') {
                linksHtml += `<a href="${project.live}" class="btn btn-primary btn-sm" target="_blank" rel="noopener noreferrer"><i class="fas fa-external-link-alt"></i> Live</a>`;
            }
            
            const delay = isNew ? '0' : '0.2';
            return `
                <div class="project-card card fade-in-up appear" id="project-${project.id}" style="transition-delay: ${delay}s;">
                    <div class="project-image">
                        <img src="/${project.image}" alt="${project.title}" class="img-placeholder" style="object-fit: cover; width: 100%; height: 200px;">
                    </div>
                    <div class="project-info">
                        <h3 class="project-title">${project.title}</h3>
                        <p class="project-desc">${project.description}</p>
                        <div class="project-links">
                            ${linksHtml}
                        </div>
                    </div>
                </div>
            `;
        }

        socket.on('projectAdded', (project) => {
            const projectsGrid = document.querySelector('.projects-grid');
            if (projectsGrid) {
                projectsGrid.insertAdjacentHTML('beforeend', buildCardHtml(project, true));
                showToast(`New project added: ${project.title}`);
            }
        });

        socket.on('projectUpdated', (project) => {
            const existingCard = document.getElementById(`project-${project.id}`);
            if (existingCard) {
                existingCard.outerHTML = buildCardHtml(project, true);
                showToast(`Project updated: ${project.title}`);
            } else {
                // If not found, just add it
                const projectsGrid = document.querySelector('.projects-grid');
                if (projectsGrid) {
                    projectsGrid.insertAdjacentHTML('beforeend', buildCardHtml(project, true));
                }
            }
        });

        socket.on('projectDeleted', (projectId) => {
            const existingCard = document.getElementById(`project-${projectId}`);
            if (existingCard) {
                existingCard.style.opacity = '0';
                setTimeout(() => existingCard.remove(), 300);
                showToast('A project was removed.');
            }
        });
    </script>
    <script src="js/script.js"></script>
</body>
</html>
